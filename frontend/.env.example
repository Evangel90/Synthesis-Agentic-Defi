# Frontend environment variables
# Copy this file to .env and fill in the placeholders before running the dev server.

# Web3Auth client configuration (required for Google + social login flows)
VITE_WEB3AUTH_CLIENT_ID=your-web3auth-google-client-id

# Optional: change if you want to point at a different Web3Auth network (default: SAPPHIRE_DEVNET)
VITE_WEB3AUTH_NETWORK=SAPPHIRE_DEVNET
